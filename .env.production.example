# Copy to .env.production on the server. Never commit the populated file.
POSTGRES_DB=openai_buildweek
POSTGRES_USER=examtwin
POSTGRES_PASSWORD=replace-with-a-long-random-password
MINIO_ROOT_USER=replace-with-a-minimum-3-character-access-key
MINIO_ROOT_PASSWORD=replace-with-a-long-random-secret
APP_JWT_SECRET=replace-with-at-least-32-random-characters
APP_CORS_ORIGINS=["https://app.example.com"]
APP_STORAGE_BUCKET=examtwin-artifacts
APP_STORAGE_PUBLIC_ENDPOINT_URL=https://files.example.com
APP_AI_ENABLED=true
APP_VERTEX_PROJECT=your-google-cloud-project
APP_VERTEX_LOCATION=global
APP_VERTEX_GENERATION_MODEL=gemini-3.5-flash
# Absolute server path to Google ADC JSON. Required only when APP_AI_ENABLED=true.
GOOGLE_APPLICATION_CREDENTIALS_HOST_PATH=/opt/examtwin/secrets/application_default_credentials.json
APP_PORT=3000
